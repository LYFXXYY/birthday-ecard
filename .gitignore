# Node_modules (所有子目录)
**/node_modules/

# 环境配置 (敏感信息)
.env
.env.local
.env.*.local

# 生成的贺卡文件 (动态生成)
generated-cards/*
!**/generated-cards/.gitkeep

# 上传文件
uploads/*
!**/uploads/.gitkeep

# 日志文件
*.log
logs/

# IDE 配置
.vscode/
.idea/
.qoder/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# 构建输出
dist/
build/

# Temp files
*.tmp
*.temp

# 代码审查与开发文档（不推送）
代码审查与优化总结报告.md
生日贺卡项目开发文档.md
