# Node_modules (所有子目录)
**/node_modules/

# 环境配置 (敏感信息)
.env
.env.local
.env.*.local

# 生成的贺卡文件 (动态生成)
**/generated-cards/*
!**/generated-cards/.gitkeep

# 生成的贺卡视频 (动态录制)
**/generated-videos/*
!**/generated-videos/.gitkeep

# 模板文件夹内预录制的示例视频
**/output.mp4

# 录制临时文件（含带时间戳后缀的变体）
**/.recording-temp*/

# 运行时心跳状态
**/heartbeats/

# 上传文件
uploads/*
!**/uploads/.gitkeep

# 日志文件
*.log
logs/

# IDE 配置
.vscode/
.idea/
.qoder/
.claude/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# 构建输出
dist/
build/

# Temp files
*.tmp
*.temp

# 代码审查与开发文档（不推送）
代码审查与优化总结报告.md
生日贺卡项目开发文档.md
server/heartbeats/monitor.json
