# ========== 主项目连接配置 ==========
MAIN_HOST=http://localhost
MAIN_PORT=3001
HEALTH_ENDPOINT=/api/health

# ========== 心跳文件路径 ==========
# 相对于 server/monitor/ 目录，指向 server/heartbeats/
HEARTBEAT_DIR=../heartbeats

# ========== 数据库配置 ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的密码
DB_NAME=你的数据库名字

# ========== 检测频率（秒） ==========
HTTP_CHECK_INTERVAL=120
PORT_CHECK_INTERVAL=300
HEARTBEAT_CHECK_INTERVAL=300
DB_CHECK_INTERVAL=300

# ========== 心跳超时阈值（小时） ==========
HEARTBEAT_TIMEOUT_HOURS=25

# ========== 日志配置 ==========
LOG_DIR=./logs
LOG_MAX_DAYS=30
