# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=birthday
DB_USER=root
DB_PASSWORD=your_password_here

# JWT配置
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=24h

# 服务器配置
PORT=3001
NODE_ENV=development

# 日志级别：trace/debug/info/warn/error/fatal（默认：开发debug，生产info）
LOG_LEVEL=debug

# 文件路径
CARDS_DIR=./generated-cards
VIDEOS_DIR=./generated-videos
UPLOADS_DIR=./uploads

# 贺卡发送者名称
SENDER_NAME=公司工会

# 短信发送配置（mock=模拟发送，carrier=运营商接口）
SMS_PROVIDER=mock
SMS_API_URL=
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=
SMS_MAX_RETRIES=3
SMS_RETRY_DELAY=1000
SMS_TIMEOUT=10000

# CSP 5G视频短信配置（中国移动北向接口 V2.4.3）
CSP_APP_ID=
CSP_PASSWORD=
CSP_SERVER_ROOT=https://api.5gcsp.mas.10086.cn/ocsp/developer
CSP_FILE_SERVER_ROOT=https://api.5gcsp.mas.10086.cn/ocsp/fileservice
CSP_CHATBOT_URI=
CSP_CALLBACK_URL=
CSP_VIDEO_TEMPLATE_ID=
CSP_TEMP_STORE_TIME=259200

# CORS 允许的前端来源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173
