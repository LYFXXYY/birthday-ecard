# 数据库配置（必填）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=birthday
DB_USER=root
DB_PASSWORD=your_database_password

# JWT配置
# 生产环境必须设置至少32字符的随机字符串
JWT_SECRET=your_random_secret_key_here_at_least_32_characters
JWT_EXPIRES_IN=24h

# 服务器配置
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# 文件存储目录
CARDS_DIR=./generated-cards
UPLOADS_DIR=./uploads

# 贺卡发送者名称（用于模板 {{sender}} 占位符）
SENDER_NAME=公司工会

# 短信发送配置（mock=模拟发送，carrier=运营商接口）
SMS_PROVIDER=mock
SMS_API_URL=
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=
SMS_MAX_RETRIES=3
SMS_RETRY_DELAY=1000
SMS_TIMEOUT=10000
